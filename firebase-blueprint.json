{
  "entities": {
    "Produto": {
      "title": "Produto",
      "description": "Produto próximo da validade cadastrado por um admin (lojista)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "nomeLoja": { "type": "string" },
        "nomeProduto": { "type": "string" },
        "categoria": { "type": "string" },
        "descricao": { "type": "string" },
        "precoOriginal": { "type": "number" },
        "precoPromocional": { "type": "number" },
        "dataValidade": { "type": "string", "format": "date" },
        "quantidadeDisponivel": { "type": "number" },
        "quantidadeReservada": { "type": "number" },
        "imageUrl": { "type": "string" },
        "imagens": { "type": "array" },
        "status": { "type": "string", "enum": [ "disponivel", "esgotado" ] },
        "endereco": { "type": "string" },
        "criadoEm": { "type": "object" }
      },
      "required": [
        "adminId",
        "nomeLoja",
        "nomeProduto",
        "categoria",
        "precoOriginal",
        "precoPromocional",
        "dataValidade",
        "quantidadeDisponivel",
        "quantidadeReservada",
        "status",
        "endereco",
        "criadoEm"
      ]
    },
    "Reserva": {
      "title": "Reserva",
      "description": "Reserva de produto feita por um consumidor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuarioId": { "type": "string" },
        "usuarioEmail": { "type": "string" },
        "produtoId": { "type": "string" },
        "nomeProduto": { "type": "string" },
        "nomeLoja": { "type": "string" },
        "quantidade": { "type": "number" },
        "precoTotal": { "type": "number" },
        "status": { "type": "string", "enum": [ "pendente", "retirado", "cancelado" ] },
        "criadoEm": { "type": "object" },
        "atualizadoEm": { "type": "object" }
      },
      "required": [
        "usuarioId",
        "usuarioEmail",
        "produtoId",
        "nomeProduto",
        "nomeLoja",
        "quantidade",
        "precoTotal",
        "status",
        "criadoEm",
        "atualizadoEm"
      ]
    },
    "Usuario": {
      "title": "Usuario",
      "description": "Perfil de usuário da plataforma com suas permissões",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "nome": { "type": "string" },
        "role": { "type": "string", "enum": [ "user", "admin" ] },
        "criadoEm": { "type": "object" }
      },
      "required": [
        "uid",
        "email",
        "nome",
        "role",
        "criadoEm"
      ]
    },
    "NotificacaoPreferencias": {
      "title": "NotificacaoPreferencias",
      "description": "Configurações de notificações de descontos para o usuário",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "cepsDesejados": { "type": "array" },
        "distanciaKm": { "type": "number" },
        "notificarNovosDescontos": { "type": "boolean" },
        "fcmTokens": { "type": "array" }
      },
      "required": [
        "uid",
        "cepsDesejados",
        "distanciaKm",
        "notificarNovosDescontos",
        "fcmTokens"
      ]
    },
    "NotificacaoFeedItem": {
      "title": "NotificacaoFeedItem",
      "description": "Um item individual no feed de notificações do usuário",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "usuarioId": { "type": "string" },
        "titulo": { "type": "string" },
        "mensagem": { "type": "string" },
        "produtoId": { "type": "string" },
        "nomeLoja": { "type": "string" },
        "precoOriginal": { "type": "number" },
        "precoPromocional": { "type": "number" },
        "lido": { "type": "boolean" },
        "criadoEm": { "type": "object" }
      },
      "required": [
        "usuarioId",
        "titulo",
        "mensagem",
        "produtoId",
        "nomeLoja",
        "precoOriginal",
        "precoPromocional",
        "lido",
        "criadoEm"
      ]
    }
  },
  "firestore": {
    "produtos/{produtoId}": {
      "schema": "Produto",
      "description": "Produtos cadastrados para venda rápida"
    },
    "reservas/{reservaId}": {
      "schema": "Reserva",
      "description": "Reservas de produtos feitas por usuários"
    },
    "usuarios/{usuarioId}": {
      "schema": "Usuario",
      "description": "Dados do perfil de usuários com controle de perfil (roles)"
    },
    "notificacoes_preferencias/{usuarioId}": {
      "schema": "NotificacaoPreferencias",
      "description": "Preferências de push e CEPs inscritos por usuário"
    },
    "notificacoes/{notificacaoId}": {
      "schema": "NotificacaoFeedItem",
      "description": "Feed de pushes recebidos indexados por usuário"
    }
  }
}
